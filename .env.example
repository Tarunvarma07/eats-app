# Application
APP_ENV=production
SECRET_KEY=CHANGE-THIS-TO-A-64-CHAR-RANDOM-HEX-STRING

# JWT
JWT_SECRET_KEY=CHANGE-THIS-TO-A-64-CHAR-RANDOM-HEX-STRING
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS (comma-separated, no wildcard in production)
ALLOWED_ORIGINS=https://your-domain.com

# Database (for Docker Compose, use db as host)
DB_HOST=db
DB_PORT=5432
DB_NAME=attendance_db
DB_USER=attendance_user
DB_PASSWORD=CHANGE-THIS-STRONG-PASSWORD

# Database URL (constructed from above, or override directly)
# DATABASE_URL=postgresql+psycopg2://attendance_user:CHANGE-THIS-STRONG-PASSWORD@db:5432/attendance_db

# Logging
LOG_LEVEL=INFO

# Nginx/Domain Configuration
DOMAIN_NAME=your-domain.com
